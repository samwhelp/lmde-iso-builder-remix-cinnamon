
[net.launchpad.plank.dock.settings]
auto-pinning=false
hide-mode='none'
theme='Gtk+'
icon-size=36
zoom-enabled=true
zoom-percent=150
dock-items=['thunar.dockitem', 'sublime_text.dockitem', 'firefox.dockitem', 'xfce4-terminal.dockitem', 'cinnamon-settings.dockitem', 'org.xfce.mousepad.dockitem', 'desktop.dockitem']
